# ============================================================================
# ENVIRONMENT CONFIGURATION FOR LMS-LOCAL BACKEND
# ============================================================================
# Copy this file to `.env` and fill in your actual values.
# The backend will FAIL TO START if required variables (marked with *) are missing.
# ============================================================================

# ────────────────────────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────
# Port to run the Express server on (default: 8080)
PORT=8080

# Node environment: development | production | test (default: development)
NODE_ENV=development

# Pino logger level: trace | debug | info | warn | error | fatal (default: info)
LOG_LEVEL=info

# ────────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION [REQUIRED]
# ────────────────────────────────────────────────────────────────────────────
# PostgreSQL connection parameters
# IMPORTANT: DB_USER, DB_SERVER, DB_NAME, and DB_PASSWORD are REQUIRED.
# The application will not start without these values.

# Database username (REQUIRED)
DB_USER=postgres

# Database server hostname or IP (REQUIRED)
DB_SERVER=localhost

# Database name (REQUIRED)
DB_NAME=lms_local

# Database password (REQUIRED)
DB_PASSWORD=your_secure_password_here

# Database port (default: 5432)
DB_PORT=5432

# Optional: Full database connection string (DATABASE_URL)
# If provided, some drivers may use this instead of individual connection params.
DATABASE_URL=

# Database connection pool size - max number of concurrent connections (default: 20)
DB_MAX_POOL_SIZE=20

# Idle timeout in milliseconds before a pool connection is closed (default: 30000)
DB_IDLE_TIMEOUT=30000

# Connection timeout in milliseconds (default: 2000)
DB_CONN_TIMEOUT=2000

# ────────────────────────────────────────────────────────────────────────────
# RATE LIMITING CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────
# Time window for rate limiting in milliseconds (default: 900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests allowed per IP in the time window (default: 1000)
RATE_LIMIT_MAX=1000

# ────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION CONFIGURATION [REQUIRED]
# ────────────────────────────────────────────────────────────────────────────
# URL for Better Auth server (REQUIRED - no fallback to localhost)
# This is the public URL where the auth service is running.
# In production, use your actual domain (e.g., https://auth.yourdomain.com)
# In development, use http://localhost:8080
BETTER_AUTH_URL=http://localhost:8080

# ────────────────────────────────────────────────────────────────────────────
# UPLOAD CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────
# Maximum file upload size in bytes (default: 10485760 = 10 MB)
UPLOAD_MAX_FILE_SIZE=10485760

# ============================================================================
# NOTES
# ============================================================================
# 1. REQUIRED VARIABLES (will cause boot failure if missing):
#    - DB_USER
#    - DB_SERVER
#    - DB_NAME
#    - DB_PASSWORD
#    - BETTER_AUTH_URL
#
# 2. OPTIONAL VARIABLES (have sensible defaults):
#    - PORT (default: 8080)
#    - NODE_ENV (default: development)
#    - LOG_LEVEL (default: info)
#    - DB_PORT (default: 5432)
#    - DB_MAX_POOL_SIZE (default: 20)
#    - DB_IDLE_TIMEOUT (default: 30000)
#    - DB_CONN_TIMEOUT (default: 2000)
#    - RATE_LIMIT_WINDOW_MS (default: 900000)
#    - RATE_LIMIT_MAX (default: 1000)
#    - UPLOAD_MAX_FILE_SIZE (default: 10485760)
#
# 3. DEVELOPMENT vs PRODUCTION:
#    - In development: Logs are displayed in the console with pino-pretty formatting.
#    - In production: Logs are output as JSON (NDJSON) for log aggregators (Datadog, CloudWatch, etc).
#
# 4. VIEWING LOGS:
#    - Development: Run `npm run dev` and read the terminal output.
#    - Production: Use your container logs or log aggregation tool.
#      Examples:
#      - Docker: `docker logs -f <container_name>`
#      - PM2: `pm2 logs`
#      - CloudWatch: Check the AWS CloudWatch Logs dashboard.
#
# ============================================================================
